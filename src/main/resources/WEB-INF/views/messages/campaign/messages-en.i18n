# Campaign Validation Errors
acme.validation.campaign.one-milestone.message = A campaign cannot be published unless it has at least one milestone
acme.validation.campaign.invalidTimeInterval.message = A campaign cannot be published with an invalid time interval. The end date must be after the start date
acme.validation.campaign.duplicated-ticker.message = This ticker is already in use by another campaign
acme.publish.campaign.noHaveMilestone.message = A campaign must have at least one milestone to be published
acme.publish.campaign.validStartMoment.message = The start date must be in the future